---
import BaseLayout from '@layouts/BaseLayout.astro'
import Header from '@components/Header.astro'
import Aside from '@components/Aside.astro'
import Newsletter from '@components/Newsletter'
import { getEpisodes, getDescriptionFromHTML } from '@utils/episodes'

const episodes = await getEpisodes()
const latest = episodes[0]
if (!latest) throw new Error('No episodes found')

const customImage = latest.markdown?.image || 'https://res.cloudinary.com/jthouk/image/upload/v1627979106/Rules%20as%20Written/lazy-bard_esoxs7.gif'
const headerImage = customImage || 'https://rulesaswrittenshow.com/raw-banner.jpg'
const description = getDescriptionFromHTML(latest.description)
---

<BaseLayout
  title={latest.title}
  description={description}
  image={customImage}
  episodes={episodes}
  currentEpisode={latest}
>
  <div class="episode-layout">
    <div class="episode-main">
      <Header episode={latest} image={headerImage} />
      <article>
        {description && <p>{description}</p>}
        <p style="padding-top: 30px;">
          If you like this show and want to help others find it,
          we would be so grateful if you rate us on
          <a href="https://podcasts.apple.com/us/podcast/rules-as-written-a-d-d-podcast/id1545377455">Apple Podcasts</a>
          and let us know what you think!
        </p>
        {latest.body && <div set:html={latest.body} style="padding-top: 30px;" />}
      </article>
      <footer class="episode-footer">
        <p>
          Can't get enough of us?
          <br />
          Stay on top of the latest releases and extra goodies by subscribing to our weekly newsletter!
        </p>
        <Newsletter client:visible />
      </footer>
      <figure class="credit-figure">
        <img src="/images/raw-logo-fancy.webp" alt="" style="max-width: 250px;" />
        <figcaption>
          Our thanks to the incredibly talented and wonderful
          <a href="https://www.linkedin.com/in/nicolejuhyunkim/" target="_blank">Nicole Kim.</a>
        </figcaption>
      </figure>
    </div>
    <Aside markdown={latest.markdown} />
  </div>
</BaseLayout>

<style>
  .episode-layout {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 992px) {
    .episode-layout {
      flex-direction: row;
    }
  }

  .episode-main {
    max-width: 100%;
  }

  @media (min-width: 992px) {
    .episode-main {
      max-width: 650px;
    }
  }

  article {
    padding: var(--space-5);
    padding-bottom: var(--space-2);
  }

  @media (min-width: 992px) {
    article {
      padding: var(--space-8);
      padding-bottom: var(--space-14);
    }
  }

  .episode-footer {
    padding: var(--space-5);
    text-align: center;
  }

  .episode-footer p {
    margin-bottom: var(--space-5);
  }

  .credit-figure {
    text-align: center;
    margin-top: var(--space-4);
    padding-bottom: var(--space-9);
  }
</style>
