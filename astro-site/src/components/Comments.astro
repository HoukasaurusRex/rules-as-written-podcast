---
interface Props {
  term?: string
}

const { term } = Astro.props
---

<div class="giscus-wrapper">
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="HoukasaurusRex/rules-as-written-podcast"
    data-repo-id="MDEwOlJlcG9zaXRvcnkzMjIyODU4NzM="
    data-category="General"
    data-category-id="DIC_kwDOEzWxMc4C3-7X"
    data-mapping="specific"
    data-term={term}
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="dark_dimmed"
    data-lang="en"
    crossorigin="anonymous"
    async
  />
</div>

<style>
  .giscus-wrapper {
    padding: var(--space-5);
    max-width: 650px;
  }

  @media (min-width: 992px) {
    .giscus-wrapper {
      padding: var(--space-8);
    }
  }
</style>
