{
  "name": "rules-as-written-podcast",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "netlify dev",
    "build": "astro build",
    "fetch-srd": "tsx scripts/fetch-srd-data.ts",
    "preview": "astro preview",
    "check": "astro check",
    "generate-article": "tsx scripts/generate-article.ts",
    "test:e2e": "yarn playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ci": "start-server-and-test 'serve dist -l 4173' http://localhost:4173 'yarn test:e2e'",
    "prepare": "husky",
    "postinstall": "rm -rf node_modules/.vite",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env --import tsx/esm scripts/seed-db.ts"
  },
  "dependencies": {
    "@astrojs/netlify": "^6.6.5",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.17",
    "@google/generative-ai": "^0.24.1",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.48",
    "@lottiefiles/dotlottie-react": "^0.18.4",
    "@nanostores/react": "^0.8.0",
    "@netlify/otel": "^5.1.3",
    "@tailwindcss/vite": "^4.2.1",
    "assemblyai": "^4.27.0",
    "astro": "^5.18.0",
    "drizzle-orm": "^0.45.1",
    "fast-xml-parser": "^5.2.0",
    "fuse.js": "^7.1.0",
    "nanostores": "^0.11.0",
    "postgres": "^3.4.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.2.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@netlify/functions": "^5.1.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "netlify-cli": "^24.2.0",
    "serve": "^14.2.6",
    "start-server-and-test": "^2.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@netlify/otel": "^5.1.3"
  }
}
