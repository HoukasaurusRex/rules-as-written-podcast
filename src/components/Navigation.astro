---
import type { Episode } from '../utils/feed'
import '../styles/marquee.css'

interface Props {
  episodes: Episode[]
  currentEpisodeId?: string
}

const { episodes, currentEpisodeId } = Astro.props
const twoDigits = (n: number) => (n.toString().length < 2 ? `0${n}` : n)
const season = episodes[0]?.season

function slugify(s: string): string {
  return s.trim().toLowerCase().replace(/[^\w ]+/g, '').replace(/ +/g, '-')
}
---

<!-- Desktop-only sidebar navigation -->
<nav class="episodes_list" id="episodes-nav">
  <div class="nav-header">
    {/* TODO: Link to season-specific tag filter on /episodes when tags are implemented */}
    <a href="/episodes" class="season-link">
      {season ? `Season ${twoDigits(season)}` : 'All Episodes'}
    </a>
  </div>

  <ul id="menu">
    {episodes.map((episode) => {
      const slug = `/show/${episode.number}/${slugify(episode.title)}`
      const isActive = episode.id === currentEpisodeId
      return (
        <li>
          <a
            href={slug}
            class:list={['marquee marquee--hover', { active: isActive }]}
          >
            <h4 class="marquee-inner">{episode.title}</h4>
          </a>
        </li>
      )
    })}
  </ul>

  <a href="/episodes" class="more-episodes-link">More Episodes &rarr;</a>
</nav>

<script>
  function initNavigation() {
    // Highlight the currently playing episode with bars animation
    const playingSlug = localStorage.getItem('nowPlayingSlug')
    document.querySelectorAll('#menu li').forEach((li) => {
      const link = li.querySelector('a') as HTMLAnchorElement
      const isPlaying = link && playingSlug && link.getAttribute('href') === playingSlug
      li.classList.toggle('now-playing', !!isPlaying)
      // Inject bars animation if playing (reuses .bars/.bar CSS from global.css)
      if (isPlaying && !li.querySelector('.bars')) {
        const bars = document.createElement('div')
        bars.className = 'bars'
        bars.setAttribute('aria-hidden', 'true')
        for (let i = 0; i < 15; i++) {
          const bar = document.createElement('div')
          bar.className = 'bar'
          bars.appendChild(bar)
        }
        li.prepend(bars)
      } else if (!isPlaying) {
        li.querySelector('.bars')?.remove()
      }
    })

    // Detect marquee overflow
    document.querySelectorAll('.marquee').forEach((el) => {
      const inner = el.querySelector('.marquee-inner') as HTMLElement
      if (inner && inner.scrollWidth > el.clientWidth) {
        el.classList.add('is-overflowing')
      } else {
        el.classList.remove('is-overflowing')
      }
    })
  }

  document.addEventListener('astro:page-load', initNavigation)
  // Also update bars when a new episode starts playing (without navigation)
  window.addEventListener('play-episode', () => {
    // Small delay to let localStorage update first (set by PlayerH5)
    setTimeout(initNavigation, 50)
  })
</script>

<style>
  .episodes_list {
    display: none;
  }

  @media (min-width: 992px) {
    .episodes_list {
      display: flex;
      flex-direction: column;
      background-color: var(--color-bg);
      position: fixed;
      top: 56px;
      overflow: hidden;
      z-index: 2;
      max-width: var(--nav-width);
      height: calc(100vh - 56px - 70px);
      padding: var(--space-5);
      padding-top: var(--space-5);
      box-shadow: var(--color-shadow-right);
    }
  }

  .episodes_list a {
    text-decoration: none;
    color: var(--color-text);
    font-size: var(--font-size-3);
    font-weight: var(--font-weight-heading);
  }

  .nav-header {
    padding-bottom: var(--space-4);
    text-align: right;
  }

  .season-link {
    font-size: var(--font-size-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary) !important;
    opacity: 0.9;
  }

  .season-link:hover {
    opacity: 1;
  }

  .more-episodes-link {
    display: block;
    text-align: center;
    padding: var(--space-4) var(--space-5);
    color: var(--color-primary-lighten-50) !important;
    font-size: var(--font-size-2);
    border-top: 1px solid var(--color-bg-lighten-10);
    flex-shrink: 0;
  }

  .more-episodes-link:hover {
    color: var(--color-primary-lighten-70) !important;
  }

  ul {
    padding-bottom: var(--space-4);
    flex: 1;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 75%, transparent 100%);
  }

  li {
    padding: 0;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    position: relative;
  }

  li a {
    padding: var(--space-4) var(--space-5);
    padding-left: 24px;
    border-left: 3px solid var(--color-bg);
    font-size: var(--font-size-4);
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
    transition: border-color 0.2s, background-color 0.2s;
    /* Override marquee left fade — border needs to be fully visible */
    mask-image: linear-gradient(to right, black 0%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 0%, black 90%, transparent 100%);
  }

  li a.active {
    border-left: 3px solid var(--color-primary);
    background-color: var(--color-bg-lighten-10);
  }

  li:hover a {
    border-color: var(--color-bg-lighten-10);
  }

  li:hover a.active {
    border-color: var(--color-primary);
  }

  li h4 {
    margin-bottom: 0;
    font-size: 16px;
  }

</style>
