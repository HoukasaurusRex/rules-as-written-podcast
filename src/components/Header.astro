---
import type { Episode } from '../utils/feed'
import '../styles/marquee.css'

interface Props {
  episode: Episode
  image?: string | null
}

const { episode, image } = Astro.props
---

<header class="episode-header" style={image ? '' : `background-image: var(--color-gradient)`}>
  {image && (
    <img
      alt={episode.title}
      src={image}
      class="header-image"
    />
  )}
  <div class="header_content">
    <div class="header-bottom">
      <div class="header-info">
        <div class="header-title-wrap">
          <div class="header-title marquee marquee--scroll">
            <h1 class="marquee-inner">
              {episode.title}
              <span aria-hidden="true">{` ${episode.title}`}</span>
            </h1>
          </div>
          <h5>EP{episode.number}</h5>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .episode-header {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 250px;
    color: var(--color-text);
    overflow: hidden;
  }

  @media (min-width: 992px) {
    .episode-header {
      height: 400px;
    }
  }

  .episode-header h1 {
    font-size: var(--font-size-5);
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
    margin: 0;
  }

  @media (min-width: 992px) {
    .episode-header h1 {
      font-size: var(--font-size-8);
    }
  }

  .episode-header h5 {
    margin: var(--space-1) 0 0;
    font-size: var(--font-size-1);
    opacity: 0.6;
  }

  .header-image {
    object-fit: cover;
    max-height: 100%;
    width: 100%;
    filter: var(--color-image-filter);
  }

  @media (min-width: 992px) {
    .header-image {
      border-radius: 0 0 10px 0;
    }
  }

  .header_content {
    width: 100%;
    height: 100%;
    position: absolute;
    padding: var(--space-4);
    z-index: 1;
    display: flex;
    align-items: flex-end;
  }

  @media (min-width: 992px) {
    .header_content {
      padding: var(--space-5) var(--space-8);
    }
  }

  .header-bottom {
    width: 100%;
    padding-bottom: var(--space-4);
  }

  @media (min-width: 992px) {
    .header-bottom {
      padding-bottom: var(--space-8);
    }
  }

  .header-info {
    width: 100%;
  }

  .header-title-wrap {
    width: 100%;
  }

  /* Marquee scrolls on mobile, disabled on desktop (allow wrapping) */
  .header-title {
    max-width: 100%;
  }

  @media (min-width: 992px) {
    .header-title {
      overflow: visible;
      white-space: normal;
      mask-image: none;
      -webkit-mask-image: none;
    }

    .header-title .marquee-inner {
      animation: none;
      padding-right: 0;
    }

    /* Hide the duplicate text on desktop */
    .header-title .marquee-inner span[aria-hidden] {
      display: none;
    }
  }
</style>
