---
import type { Episode } from '../utils/feed'

interface Props {
  episode: Episode
  image?: string | null
}

const { episode, image } = Astro.props
---

<header class="episode-header" style={image ? '' : `background-image: var(--color-gradient)`}>
  {image && (
    <img
      alt={episode.title}
      src={image}
      class="header-image"
    />
  )}
  <div class="header_content">
    <img src="/images/raw-logo-fancy.webp" alt="" class="header-logo" />
    <div class="header-bottom">
      <div class="header-info">
        <div id="header-play-target" style="min-width: 32px; min-height: 32px;"></div>
        <div>
          <h1>{episode.title}</h1>
          <h5>EP{episode.number}</h5>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .episode-header {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 300px;
    color: var(--color-text);
  }

  @media (min-width: 992px) {
    .episode-header {
      height: 400px;
    }
  }

  .episode-header h1 {
    font-size: var(--font-size-6);
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    margin: 0;
  }

  @media (min-width: 992px) {
    .episode-header h1 {
      font-size: var(--font-size-8);
    }
  }

  .episode-header h5 {
    margin: var(--space-1) 0 0;
    font-size: var(--font-size-1);
    opacity: 0.6;
  }

  .header-image {
    object-fit: cover;
    max-height: 100%;
    width: 100%;
    filter: var(--color-image-filter);
  }

  @media (min-width: 992px) {
    .header-image {
      border-radius: 0 0 10px 0;
    }
  }

  .header_content {
    width: 100%;
    height: 100%;
    position: absolute;
    padding: var(--space-5) var(--space-5);
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }

  @media (min-width: 992px) {
    .header_content {
      padding: var(--space-5) var(--space-8);
    }
  }

  .header-logo {
    max-width: 25%;
    position: absolute;
    left: 0;
    top: 0;
  }

  .header-bottom {
    height: 100%;
    width: 100%;
    display: flex;
    align-items: flex-end;
    flex-direction: row;
    padding-bottom: var(--space-8);
  }

  .header-info {
    display: flex;
    width: 100%;
  }

  /* .play-episode-btn styles are in global.css (rendered via React portal) */
</style>
