---
import type { Episode } from '../utils/feed'

interface Props {
  episode: Episode
  image?: string | null
}

const { episode, image } = Astro.props
---

<header class="episode-header" style={image ? '' : `background-image: var(--color-gradient)`}>
  {image && (
    <img
      alt={episode.title}
      src={image}
      class="header-image"
    />
  )}
  <div class="header_content">
    <img src="/images/raw-logo-fancy.webp" alt="" class="header-logo" />
    <div class="header-bottom">
      <div class="header-info">
        <button
          class="play-episode-btn"
          data-episode={JSON.stringify(episode)}
          aria-label={`Play ${episode.title}`}
        >
          <span class="sr-only">Play</span>
          <svg viewBox="0 0 448 512" width="10" height="10" fill="currentColor" aria-hidden="true">
            <path d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
          </svg>
        </button>
        <div>
          <h1>{episode.title}</h1>
          <h5>EP{episode.number}</h5>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  document.querySelectorAll('.play-episode-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const data = (btn as HTMLElement).dataset.episode
      if (data) {
        const event = new CustomEvent('play-episode', { detail: JSON.parse(data) })
        window.dispatchEvent(event)
      }
    })
  })
</script>

<style>
  .episode-header {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 300px;
    color: var(--color-text);
  }

  @media (min-width: 992px) {
    .episode-header {
      height: 400px;
    }
  }

  .episode-header h1 {
    font-size: var(--font-size-6);
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    margin: 0;
  }

  @media (min-width: 992px) {
    .episode-header h1 {
      font-size: var(--font-size-8);
    }
  }

  .episode-header h5 {
    margin: var(--space-1) 0 0;
    font-size: var(--font-size-1);
    opacity: 0.6;
  }

  .header-image {
    object-fit: cover;
    max-height: 100%;
    width: 100%;
    filter: var(--color-image-filter);
  }

  @media (min-width: 992px) {
    .header-image {
      border-radius: 0 0 10px 0;
    }
  }

  .header_content {
    width: 100%;
    height: 100%;
    position: absolute;
    padding: var(--space-5) var(--space-5);
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }

  @media (min-width: 992px) {
    .header_content {
      padding: var(--space-5) var(--space-8);
    }
  }

  .header-logo {
    max-width: 25%;
    position: absolute;
    left: 0;
    top: 0;
  }

  .header-bottom {
    height: 100%;
    width: 100%;
    display: flex;
    align-items: flex-end;
    flex-direction: row;
    padding-bottom: var(--space-8);
  }

  .header-info {
    display: flex;
    width: 100%;
  }

  .play-episode-btn {
    width: 100%;
    max-width: var(--space-7);
    height: var(--space-7);
    background: transparent;
    border: 1px solid var(--color-text);
    color: var(--color-text);
    font-size: 10px;
    border-radius: var(--radius-0);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    margin-right: var(--space-3);
    margin-top: var(--space-2);
  }

  .play-episode-btn svg {
    margin-top: 1px;
    margin-left: 2px;
  }
</style>
