---
interface Props {
  term?: string
}

const { term } = Astro.props
---

<div class="giscus-wrapper" data-giscus-term={term}></div>

<script>
  function loadGiscus() {
    const wrappers = document.querySelectorAll('.giscus-wrapper')
    wrappers.forEach((wrapper) => {
      // Clear previous giscus instance (for View Transitions re-navigation)
      const existing = wrapper.querySelector('.giscus')
      if (existing) existing.remove()
      const oldScript = wrapper.querySelector('script')
      if (oldScript) oldScript.remove()

      const term = (wrapper as HTMLElement).dataset.giscusTerm || ''
      const script = document.createElement('script')
      script.src = 'https://giscus.app/client.js'
      script.setAttribute('data-repo', 'HoukasaurusRex/rules-as-written-podcast')
      script.setAttribute('data-repo-id', 'MDEwOlJlcG9zaXRvcnkzMjIyODU4NzM=')
      script.setAttribute('data-category', 'Episode Discussions')
      script.setAttribute('data-category-id', 'DIC_kwDOEzWxMc4C3-7X')
      script.setAttribute('data-mapping', 'specific')
      script.setAttribute('data-term', term)
      script.setAttribute('data-strict', '0')
      script.setAttribute('data-reactions-enabled', '1')
      script.setAttribute('data-emit-metadata', '0')
      script.setAttribute('data-input-position', 'top')
      script.setAttribute('data-theme', `${window.location.origin}/giscus-theme.css?v=2`)
      script.setAttribute('data-lang', 'en')
      script.setAttribute('crossorigin', 'anonymous')
      script.async = true
      wrapper.appendChild(script)
    })
  }

  document.addEventListener('astro:page-load', loadGiscus)
</script>

<style>
  .giscus-wrapper {
    padding: 0 var(--space-5);
    width: 100%;
  }

  @media (min-width: 992px) {
    .giscus-wrapper {
      padding: 0 var(--space-8);
    }
  }
</style>
