---
const links = [
  { href: '/', label: 'Home' },
  { href: '/episodes', label: 'Episodes' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
]

const currentPath = Astro.url.pathname
---

<nav class="site-nav">
  <a href="/" class="site-nav-logo">
    <img src="/images/raw-logo-fancy.webp" alt="" class="site-nav-logo-img" />
    <span class="site-nav-logo-text">Rules as Written</span>
  </a>
  <div class="site-nav-links">
    {links.map(({ href, label }) => (
      <a href={href} class:list={[{ active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}>
        {label}
      </a>
    ))}
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--color-bg-lighten-10);
    background-color: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  @media (min-width: 992px) {
    .site-nav {
      padding: var(--space-3) var(--space-6);
    }
  }

  .site-nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-size: var(--font-size-3);
    font-weight: var(--font-weight-heading);
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-nav-logo:hover {
    color: var(--color-primary-lighten-10);
  }

  .site-nav-logo-img {
    height: 28px;
    width: auto;
  }

  .site-nav-logo-text {
    display: none;
  }

  @media (min-width: 600px) {
    .site-nav-logo-text {
      display: inline;
    }
  }

  .site-nav-links {
    display: flex;
    gap: var(--space-3);
  }

  @media (min-width: 600px) {
    .site-nav-links {
      gap: var(--space-5);
    }
  }

  .site-nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--font-size-1);
    opacity: 0.7;
    transition: opacity 0.2s, color 0.2s;
  }

  @media (min-width: 600px) {
    .site-nav-links a {
      font-size: var(--font-size-2);
    }
  }

  .site-nav-links a:hover,
  .site-nav-links a.active {
    opacity: 1;
    color: var(--color-primary-lighten-50);
  }
</style>
