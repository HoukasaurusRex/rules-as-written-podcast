---
interface Props {
  markdown?: {
    title: string
    summary?: string | null
    image?: string | null
    resources?: string[] | null
    guestName?: string | null
    guestPhoto?: string | null
    guestSummary?: string | null
  }
}

const spotifyUrl = 'https://open.spotify.com/show/3QsthThGhfigIwbGHauPfQ'
const appleUrl = 'https://podcasts.apple.com/us/podcast/rules-as-written-a-d-d-podcast/id1545377455'
const googleUrl = 'https://podcasts.google.com/feed/aHR0cHM6Ly9hbmNob3IuZm0vcy80NGE0Mjc3Yy9wb2RjYXN0L3Jzcw'
const patreonUrl = 'https://www.patreon.com/RulesAsWritten'
const email = 'toby@rulesaswrittenshow.com'
const patrons = ['Kaitlyn Witman']

const { markdown } = Astro.props
---

<aside class="sidebar">
  <div class="provider-links">
    <a href={`mailto:${email}`} class="contact-link">
      <img src="/images/mail.svg" alt="" height="25" class="mail-icon" />
      <span>Contact Us</span>
    </a>

    <a href={spotifyUrl} target="_blank" rel="noopener noreferrer" class="provider-link">
      <img src="/images/spotify-dark.png" alt="Spotify" width="90" height="25" />
    </a>

    <a href={appleUrl} target="_blank" rel="noopener noreferrer" class="provider-link">
      <img src="/images/apple-dark.svg" alt="Apple Podcasts" height="25" />
    </a>

    <a href={googleUrl} target="_blank" rel="noopener noreferrer" class="provider-link">
      <img src="/images/google-dark.svg" alt="Google Podcasts" height="22" />
    </a>

    <a href={patreonUrl} target="_blank" rel="noopener noreferrer" class="provider-link">
      <img src="/images/patreon-dark.png" alt="Support us on Patreon" height="20" />
    </a>
  </div>

  {markdown?.guestName && (
    <div class="guest-section">
      <h5 class="guest">Guest</h5>
      {markdown.guestPhoto && (
        <img
          src={markdown.guestPhoto}
          alt={markdown.guestName}
          class="guest-photo"
        />
      )}
      <h4 class="guest-name">{markdown.guestName}</h4>
      {markdown.guestSummary && <p>{markdown.guestSummary}</p>}
    </div>
  )}

  {markdown?.resources && markdown.resources.length > 0 && (
    <div>
      <h5>Resources</h5>
      <ul>
        {markdown.resources.map((resource) => (
          <li>
            <svg viewBox="0 0 512 512" width="12" height="12" fill="currentColor" class="external-icon" aria-hidden="true">
              <path d="M432 320H400a16 16 0 0 0-16 16V448H64V128H208a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16H48A48 48 0 0 0 0 112V464a48 48 0 0 0 48 48H400a48 48 0 0 0 48-48V336A16 16 0 0 0 432 320zM488 0H360c-21.37 0-32.05 25.91-17 41l35.73 35.73L135 320.37a24 24 0 0 0 0 34L157.67 377a24 24 0 0 0 34 0L435.28 133.32 471 169c15 15 41 4.5 41-17V24A24 24 0 0 0 488 0z"/>
            </svg>
            <Fragment set:html={resource} />
          </li>
        ))}
      </ul>
    </div>
  )}

  {patrons.length > 0 && (
    <div>
      <h5>Special Thanks to our Top Patrons</h5>
      <ul>
        {patrons.map((patron) => (
          <li>{patron}</li>
        ))}
      </ul>
    </div>
  )}
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    padding-bottom: var(--space-13);
    width: 100%;
    max-width: 100%;
    font-size: 15px;
  }

  @media (min-width: 992px) {
    .sidebar {
      padding: var(--space-8);
      padding-bottom: var(--space-8);
      max-width: 250px;
    }
  }

  .sidebar h5 {
    margin: var(--space-4) 0;
    font-size: var(--font-size-3);
  }

  .sidebar h5:not(:first-of-type) {
    margin-bottom: var(--space-10);
    margin-top: 0;
  }

  .provider-links {
    margin-bottom: var(--space-2);
  }

  @media (min-width: 992px) {
    .provider-links {
      padding-right: 0;
    }
  }

  .provider-links a {
    color: var(--color-text);
    text-decoration: none;
  }

  .contact-link {
    display: flex;
    font-size: 16px;
    font-weight: bold;
    margin-bottom: var(--space-5);
    align-items: center;
  }

  .mail-icon {
    height: 25px;
    margin-right: var(--space-2);
  }

  .provider-link {
    margin-bottom: var(--space-5);
    display: flex;
    align-items: center;
  }

  .provider-link img {
    margin: 0;
    margin-right: var(--space-3);
  }

  .guest {
    font-size: var(--font-size-1);
    text-transform: uppercase;
    opacity: 0.8;
    font-weight: var(--font-weight-body);
  }

  .guest-photo {
    border-radius: var(--radius-0);
    width: 100%;
    max-width: 100px;
    object-fit: cover;
  }

  .guest-name {
    margin-top: var(--space-3);
    margin-bottom: var(--space-1);
  }

  .sidebar li {
    margin-bottom: var(--space-2);
    display: flex;
  }

  .sidebar li a {
    color: var(--color-text);
  }

  .external-icon {
    margin-top: var(--space-1);
    margin-right: var(--space-1);
    width: 100%;
    max-width: var(--space-3);
    color: var(--color-text);
    opacity: 0.5;
    flex-shrink: 0;
  }
</style>
