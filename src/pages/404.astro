---
export const prerender = true

import BaseLayout from '@layouts/BaseLayout.astro'
---

<BaseLayout title="404 - Here There Be Dragons">
  <main id="main" class="flex min-h-screen items-center justify-center text-center">
    <div class="max-w-lg px-8">
      <h1 style="font-size: var(--font-size-8); color: var(--color-primary);">404</h1>
      <h2 style="font-size: var(--font-size-6);">Here There Be Dragons</h2>
      <p class="mb-8 opacity-80">
        You've wandered off the map, adventurer. The page you seek lies beyond the edges of our realm.
      </p>
      <a href="/" class="inline-block rounded px-6 py-3" style="background: var(--color-primary); color: white; text-decoration: none;">
        Return to the Tavern
      </a>
    </div>
  </main>
</BaseLayout>
