---
export const prerender = true

import BaseLayout from '@layouts/BaseLayout.astro'
import SiteNav from '@components/SiteNav.astro'
import { getEpisodes, getDescriptionFromHTML } from '@utils/episodes'
import { slugify } from '@utils/slugify'

const episodes = await getEpisodes()
---

<BaseLayout title="All Episodes | Rules as Written" description="Browse all episodes of the Rules as Written D&D podcast.">
  <SiteNav />
  <main id="main" class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="mb-2" style="color: var(--color-primary);">Episodes</h1>
    <p class="mb-6 opacity-80">Browse all {episodes.length} episodes of Rules as Written.</p>

    <div class="mb-8">
      <input
        type="search"
        id="episode-search"
        placeholder="Search episodes..."
        class="w-full rounded border px-4 py-3"
        style="background: var(--color-bg-lighten-10); border-color: var(--color-bg-lighten-20); color: var(--color-text);"
      />
    </div>

    <div id="episode-list" class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
      {episodes.map((episode) => {
        const slug = `/show/${episode.number}/${slugify(episode.title)}`
        const description = getDescriptionFromHTML(episode.description)
        const image = episode.markdown?.image
        return (
          <a href={slug} class="episode-card" data-title={episode.title.toLowerCase()} data-episode-id={episode.id}>
            {image && (
              <img src={image} alt="" class="episode-card-image" loading="lazy" />
            )}
            <div class="episode-card-body">
              <span class="episode-card-number">EP{episode.number}</span>
              <h3 class="episode-card-title">{episode.title}</h3>
              {description && (
                <p class="episode-card-desc">{description.slice(0, 120)}{description.length > 120 ? '...' : ''}</p>
              )}
            </div>
          </a>
        )
      })}
    </div>

    <p id="no-results" class="hidden py-8 text-center opacity-60">No episodes found matching your search.</p>
  </main>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const search = document.getElementById('episode-search') as HTMLInputElement | null
    const cards = document.querySelectorAll('.episode-card') as NodeListOf<HTMLElement>
    const noResults = document.getElementById('no-results')

    // Search filtering
    if (search && noResults) {
      search.addEventListener('input', () => {
        const query = search.value.toLowerCase().trim()
        let visible = 0
        cards.forEach((card) => {
          const title = card.dataset.title ?? ''
          const match = !query || title.includes(query)
          card.style.display = match ? '' : 'none'
          if (match) visible++
        })
        noResults.classList.toggle('hidden', visible > 0)
      })
    }

    // Highlight currently playing episode (from localStorage, not page data)
    const playingId = localStorage.getItem('nowPlayingEpisodeId')
    if (playingId) {
      cards.forEach((card) => {
        const isPlaying = card.dataset.episodeId === playingId
        card.classList.toggle('now-playing', isPlaying)
        if (isPlaying && !card.querySelector('.eq-bars')) {
          const barsEl = document.createElement('div')
          barsEl.className = 'eq-bars'
          barsEl.innerHTML = '<span></span><span></span><span></span><span></span>'
          const body = card.querySelector('.episode-card-body')
          if (body) body.prepend(barsEl)
        }
      })
    }
  })
</script>

<style>
  .episode-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-0);
    overflow: hidden;
    background: var(--color-bg-lighten-10);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .episode-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--color-shadow);
    color: var(--color-text);
  }

  .episode-card-image {
    width: 100%;
    height: 160px;
    object-fit: cover;
  }

  .episode-card-body {
    padding: var(--space-4);
  }

  .episode-card-number {
    font-size: var(--font-size-0);
    text-transform: uppercase;
    opacity: 0.6;
    font-weight: var(--font-weight-heading);
  }

  .episode-card-title {
    font-size: var(--font-size-3);
    margin: var(--space-1) 0 var(--space-2);
  }

  .episode-card-desc {
    font-size: var(--font-size-1);
    opacity: 0.7;
    margin: 0;
    line-height: 1.5;
  }

  /* Currently playing episode highlight — uses global .now-playing and .eq-bars from global.css */
</style>
